export interface NoteSection {
  title: string
  content: string
  examples?: Array<{
    title: string
    content: string
  }>
  tips?: string[]
}

export interface ChapterNotes {
  id: string
  title: string
  summary: string
  sections: NoteSection[]
  formulas?: string[]
  commonMistakes?: string[]
}

// 第1章：有理数 笔记
export const ch1Notes: ChapterNotes = {
  id: 'ch1',
  title: '第1章 有理数',
  summary: '有理数是初中数学的基础，本章从正数和负数的概念引入，学习有理数的表示、比较大小和四则运算。',
  sections: [
    {
      title: '1.1 正数和负数',
      content: `📌 正数：大于0的数，如 1, 2.5, 3/4
📌 负数：小于0的数，如 -1, -3.2, -5/6
📌 0：既不是正数也不是负数

🔑 用正负数表示相反意义的量：
• 上升/下降：上升5米记作 +5米，下降3米记作 -3米
• 收入/支出：收入100元记作 +100元，支出50元记作 -50元
• 向东/向西：向东走记为正，向西走记为负
• 零上/零下：零上10℃记作 +10℃，零下5℃记作 -5℃`,
      examples: [
        {
          title: '例题1',
          content: '如果水位上升0.5米记作+0.5米，那么水位下降1.2米记作什么？\n\n解：上升记为正，则下降记为负\n答案：-1.2米'
        },
        {
          title: '例题2',
          content: '某班级男生平均身高记为0厘米，小明身高比平均高5厘米记作+5厘米，小红比平均矮3厘米记作什么？\n\n解：高于平均为正，低于平均为负\n答案：-3厘米'
        }
      ],
      tips: ['相反意义的量必须意义相反，且单位相同', '0是正负数的分界点']
    },
    {
      title: '1.2 数轴',
      content: `📌 数轴三要素：
1. 原点：表示0的点
2. 正方向：通常向右为正
3. 单位长度：根据需要选取

📌 数轴上的点与数的关系：
• 每个有理数都可以用数轴上的一个点表示
• 原点右边的点表示正数，左边的点表示负数
• 右边的数总比左边的数大

🔑 利用数轴比较大小：
在数轴上，右边的数总比左边的大。
例如：-3 < -1 < 0 < 2 < 5`,
      examples: [
        {
          title: '例题',
          content: '在数轴上表示-3、0、2.5、-1.5这四个数，并用"<"连接。\n\n解：在数轴上从左到右依次是：-3, -1.5, 0, 2.5\n答案：-3 < -1.5 < 0 < 2.5'
        }
      ],
      tips: ['数轴是理解有理数大小关系的重要工具', '比较大小时可以先在数轴上标出各数']
    },
    {
      title: '1.3 相反数',
      content: `📌 定义：只有符号不同的两个数互为相反数

📌 性质：
• 正数的相反数是负数
• 负数的相反数是正数
• 0的相反数是0

🔑 表示方法：
a的相反数是 -a
-a的相反数是 a
-( -a ) = a

📌 几何意义：在数轴上，互为相反数的两个数关于原点对称`,
      examples: [
        {
          title: '例题1',
          content: '-7的相反数是多少？\n\n答案：7'
        },
        {
          title: '例题2',
          content: '化简：-(-5) = ?\n\n解：负负得正\n答案：5'
        }
      ],
      tips: ['求一个数的相反数，只需改变符号', '多重符号化简：负号个数为偶数得正，奇数得负']
    },
    {
      title: '1.4 绝对值',
      content: `📌 定义：数轴上表示数a的点与原点的距离叫做数a的绝对值，记作 |a|

📌 性质：
• 正数的绝对值是它本身：|a| = a (a > 0)
• 负数的绝对值是它的相反数：|a| = -a (a < 0)
• 0的绝对值是0：|0| = 0

🔑 重要结论：
• |a| ≥ 0（绝对值总是非负的）
• 互为相反数的两个数绝对值相等：|a| = |-a|
• 若 |a| = |b|，则 a = b 或 a = -b`,
      examples: [
        {
          title: '例题',
          content: '计算：|-9| = ?，|5| = ?，|-3.6| = ?\n\n解：\n|-9| = 9（负数的绝对值是它的相反数）\n|5| = 5（正数的绝对值是它本身）\n|-3.6| = 3.6\n\n答案：9，5，3.6'
        }
      ],
      tips: ['绝对值表示距离，所以不可能为负', '|a| = b (b>0) 时，a = b 或 a = -b']
    },
    {
      title: '1.5 有理数的大小比较',
      content: `📌 法则：
1. 正数 > 0 > 负数
2. 两个正数，绝对值大的数大
3. 两个负数，绝对值大的反而小

🔑 比较两个负数的方法：
先比较绝对值，绝对值大的那个数反而小。

例如：比较 -5 和 -3
|-5| = 5，|-3| = 3
因为 5 > 3，所以 -5 < -3`,
      examples: [
        {
          title: '例题',
          content: '比较大小：-4 和 -6\n\n解：\n|-4| = 4，|-6| = 6\n因为 4 < 6（绝对值小的负数反而大）\n所以 -4 > -6\n\n答案：-4 > -6'
        }
      ],
      tips: ['比较负数时，绝对值大的反而小', '可以借助数轴直观比较']
    },
    {
      title: '1.6 有理数的加法',
      content: `📌 法则：
1. 同号两数相加：取相同的符号，绝对值相加
   (+3) + (+5) = +8
   (-3) + (-5) = -8

2. 异号两数相加：取绝对值较大的数的符号，绝对值相减
   (+7) + (-3) = +4
   (-7) + (+3) = -4

3. 任何数与0相加，仍得这个数
   a + 0 = a

🔑 加法运算律：
• 交换律：a + b = b + a
• 结合律：(a + b) + c = a + (b + c)`,
      examples: [
        {
          title: '例题1',
          content: '计算：(-7) + (-4) = ?\n\n解：同号相加，取负号，绝对值相加\n答案：-11'
        },
        {
          title: '例题2',
          content: '计算：(-5) + 8 = ?\n\n解：异号相加，取正号（因为|8|>|5|），绝对值相减\n答案：3'
        }
      ],
      tips: ['先确定符号，再计算绝对值', '多个数相加时，可以先把同号的数相加']
    },
    {
      title: '1.7 有理数的减法',
      content: `📌 法则：减去一个数，等于加上这个数的相反数

a - b = a + (-b)

🔑 计算步骤：
1. 把减号变加号
2. 把减数变成它的相反数
3. 按加法法则计算

例如：
(-15) - (-8) = (-15) + 8 = -7
5 - 9 = 5 + (-9) = -4`,
      examples: [
        {
          title: '例题',
          content: '计算：(-15) - (-8) = ?\n\n解：\n(-15) - (-8) \n= (-15) + 8  （减变加，-8变+8）\n= -7\n\n答案：-7'
        }
      ],
      tips: ['减法变加法：减号变加号，减数变相反数', '有理数减法都可以转化为加法来计算']
    },
    {
      title: '1.8 有理数的乘除法',
      content: `📌 乘法法则：
1. 同号得正，异号得负
2. 任何数与0相乘，都得0

📌 除法法则：
除以一个不为0的数，等于乘这个数的倒数
a ÷ b = a × (1/b) (b≠0)

🔑 符号法则（乘除相同）：
• 同号得正：(+)×(+)=(+)，(-)×(-)=(+)
• 异号得负：(+)×(-)=(-)，(-)×(+)=(-)

多个数相乘：负因数的个数为偶数时积为正，奇数时积为负。`,
      examples: [
        {
          title: '例题1',
          content: '计算：(-6) × 7 = ?\n\n解：异号得负，6×7=42\n答案：-42'
        },
        {
          title: '例题2',
          content: '计算：(-12) ÷ (-3) = ?\n\n解：同号得正，12÷3=4\n答案：4'
        }
      ],
      tips: ['先确定符号，再计算绝对值', '除法转化为乘法：除以一个数=乘它的倒数']
    },
    {
      title: '1.9 有理数的乘方',
      content: `📌 定义：求n个相同因数的积的运算，叫做乘方

aⁿ 读作"a的n次方"或"a的n次幂"
• a 叫做底数
• n 叫做指数
• 结果叫做幂

📌 符号法则：
• 正数的任何次幂都是正数
• 负数的奇次幂是负数，偶次幂是正数
• 0的任何正整数次幂都是0

🔑 注意：
-2⁴ = -(2⁴) = -16  （先算2的4次方，再取负）
(-2)⁴ = 16  （-2的4次方，负数的偶次幂为正）`,
      examples: [
        {
          title: '例题',
          content: '计算：(-2)³ = ?\n\n解：负数的奇次幂是负数\n(-2)³ = (-2) × (-2) × (-2) = -8\n\n答案：-8'
        }
      ],
      tips: ['注意区分 -aⁿ 和 (-a)ⁿ', '负数的偶次幂为正，奇次幂为负']
    },
    {
      title: '1.10 科学记数法',
      content: `📌 定义：把一个大于10的数表示成 a×10ⁿ 的形式

其中：
• 1 ≤ a < 10
• n 是正整数（原数的整数位数减1）

🔑 转换方法：
• 小数点向左移动几位，n就是几
• 5670000 = 5.67×10⁶
• 0.0000123 = 1.23×10⁻⁵（小于1的数，n为负）

📌 还原方法：
a×10ⁿ → 小数点向右移动n位`,
      examples: [
        {
          title: '例题1',
          content: '用科学记数法表示：5600000\n\n解：小数点向左移6位\n答案：5.6×10⁶'
        },
        {
          title: '例题2',
          content: '用科学记数法表示：125000\n\n解：小数点向左移5位\n答案：1.25×10⁵'
        }
      ],
      tips: ['科学记数法便于表示大数和小数', '注意a的范围是1≤a<10']
    }
  ],
  formulas: [
    '|a| = { a (a≥0), -a (a<0) }',
    'a - b = a + (-b)',
    'a ÷ b = a × (1/b) (b≠0)',
    '同号相加：+(|a|+|b|)，异号相加：±||a|-|b||'
  ],
  commonMistakes: [
    '混淆 -aⁿ 和 (-a)ⁿ 的区别',
    '两个负数比较大小，认为绝对值大的数就大',
    '减法变加法时，只改变运算符号而忘记改变减数的符号',
    '多个负数相乘时，符号判断错误'
  ]
}

// 第2章：整式的加减 笔记
export const ch2Notes: ChapterNotes = {
  id: 'ch2',
  title: '第2章 整式的加减',
  summary: '本章从单项式、多项式的概念出发，学习同类项的识别与合并，以及整式的加减运算。',
  sections: [
    {
      title: '2.1 单项式',
      content: `📌 定义：由数与字母的积组成的代数式叫做单项式

📌 单独的一个数或一个字母也是单项式
例如：-3，x，2ab 都是单项式

🔑 系数：单项式中的数字因数
• 单项式 -3xy² 的系数是 -3
• 单项式 a 的系数是 1（省略不写）
• 单项式 -x 的系数是 -1

🔑 次数：单项式中所有字母的指数和
• 单项式 5a³b 的次数是 3+1=4
• 单项式 -2x²y³z 的次数是 2+3+1=6
• 常数项的次数是0`,
      examples: [
        {
          title: '例题',
          content: '单项式 -3xy²z 的系数和次数分别是？\n\n解：\n系数是 -3\n次数是 1+2+1=4（x的指数1，y的指数2，z的指数1）\n\n答案：系数-3，次数4'
        }
      ],
      tips: ['系数包括前面的符号', '次数只算字母的指数，不算系数']
    },
    {
      title: '2.2 多项式',
      content: `📌 定义：几个单项式的和叫做多项式

例如：2x² - 3x + 1 是多项式（三个单项式2x²、-3x、1的和）

🔑 项：多项式中的每个单项式
• 2x² - 3x + 1 有三项：2x²、-3x、1
• 每一项都包括前面的符号

🔑 次数：多项式中次数最高的项的次数
• 2x³ - x² + 3x - 7 的次数是3
• 多项式的次数不一定等于项数

🔑 常数项：不含字母的项
• 2x² - 3x + 1 的常数项是1
• -5x + 7 的常数项是7

📌 多项式的排列：
• 按某字母的降幂排列：指数从大到小
• 按某字母的升幂排列：指数从小到大`,
      examples: [
        {
          title: '例题',
          content: '多项式 2x³ - x² + 3x - 7 有几项？次数是多少？常数项是多少？\n\n解：\n有4项：2x³、-x²、3x、-7\n次数是3（最高次项2x³的次数）\n常数项是-7\n\n答案：4项，次数3，常数项-7'
        }
      ],
      tips: ['多项式的次数不是所有项次数之和，而是最高次项的次数', '项数是指单项式的个数']
    },
    {
      title: '2.3 同类项',
      content: `📌 定义：所含字母相同，并且相同字母的指数也相同的项叫做同类项

🔑 几个常数项也是同类项

📌 判断同类项的条件（两相同）：
1. 所含字母相同
2. 相同字母的指数相同

例如：
• 3a²b 与 -5a²b 是同类项 ✓
• 3a²b 与 3ab² 不是同类项 ✗（a、b的指数不同）
• 3a²b 与 3a²c 不是同类项 ✗（字母不同）
• 3a² 与 3a 不是同类项 ✗（a的指数不同）`,
      examples: [
        {
          title: '例题',
          content: '下列各组中，是同类项的是？\nA. 2x 与 2y\nB. 3a²b 与 -ba²\nC. 5mn 与 5m\nD. 3x² 与 3x\n\n解：\nA：字母不同，不是同类项\nB：字母相同（a²b），顺序不同不影响，是同类项 ✓\nC：字母不完全相同（多了n），不是同类项\nD：x的指数不同，不是同类项\n\n答案：B'
        }
      ],
      tips: ['同类项与系数无关', '同类项与字母顺序无关', '所有常数项都是同类项']
    },
    {
      title: '2.4 合并同类项',
      content: `📌 法则：把同类项的系数相加，字母和字母的指数不变

🔑 口诀：系数相加，字母不变

例如：
3x + 5x = (3+5)x = 8x
-2a²b + 7a²b = (-2+7)a²b = 5a²b

📌 步骤：
1. 找出同类项（可标记）
2. 将同类项的系数相加
3. 字母和指数保持不变

⚠️ 注意：不是同类项不能合并！
如：3x + 2y 不能合并
如：2a² + 3a 不能合并`,
      examples: [
        {
          title: '例题',
          content: '合并同类项：3x² - 2x + 5x² + 4x\n\n解：\n原式 = (3x² + 5x²) + (-2x + 4x)\n     = 8x² + 2x\n\n答案：8x² + 2x'
        }
      ],
      tips: ['合并前最好先把同类项放在一起', '注意符号，特别是负号']
    },
    {
      title: '2.5 去括号',
      content: `📌 法则：
1. 括号前是"+"号，去括号后各项符号不变
   +(a - b) = a - b
   +(3x + 2y) = 3x + 2y

2. 括号前是"-"号，去括号后各项符号都变
   -(a - b) = -a + b
   -(3x + 2y) = -3x - 2y

3. 括号前有系数，先用分配律
   2(3x + 4) = 6x + 8
   -3(2a - b) = -6a + 3b

🔑 去括号口诀：
正不变，负全变，系数要分配`,
      examples: [
        {
          title: '例题',
          content: '去括号：2x + (3y - z) = ?\n\n解：括号前是正号，去括号后各项符号不变\n答案：2x + 3y - z'
        },
        {
          title: '例题2',
          content: '去括号：-(2a - 3b) = ?\n\n解：括号前是负号，去括号后各项符号都变\n-2a 变成 +2a？不对！\n-(2a - 3b) = -2a + 3b\n\n答案：-2a + 3b'
        }
      ],
      tips: ['去括号时，括号前的符号要跟着走', '括号前有负号是最容易出错的地方！']
    },
    {
      title: '2.6 整式的加减',
      content: `📌 整式加减的实质：去括号 + 合并同类项

🔑 步骤：
1. 去括号（注意符号）
2. 找同类项
3. 合并同类项

📌 化简求值：
1. 先化简整式
2. 再代入数值计算
3. 注意：代入负数或分数时要加括号`,
      examples: [
        {
          title: '例题',
          content: '化简：(2a + 3b) - (a - 2b)\n\n解：\n= 2a + 3b - a + 2b  （去括号，第二个括号前是负号，各项变号）\n= (2a - a) + (3b + 2b)  （合并同类项）\n= a + 5b\n\n答案：a + 5b'
        },
        {
          title: '例题2',
          content: '化简求值：3(2x² - xy) - 2(x² + 2xy)，其中x=1，y=-2\n\n解：\n= 6x² - 3xy - 2x² - 4xy\n= 4x² - 7xy\n\n当x=1，y=-2时：\n原式 = 4(1)² - 7(1)(-2)\n     = 4 + 14\n     = 18\n\n答案：18'
        }
      ],
      tips: ['去括号时注意符号变化', '代入求值时，负数要加括号', '先化简再求值更简便']
    }
  ],
  formulas: [
    '同类项合并：系数相加，字母不变',
    '去括号：正不变，负全变，系数要分配'
  ],
  commonMistakes: [
    '去括号时，括号前是负号忘记变号',
    '合并同类项时，字母的指数也相加了',
    '代入求值时，负数忘记加括号',
    '判断同类项时，忽略了字母的顺序可以不同'
  ]
}

// 所有章节笔记
export const allNotes: ChapterNotes[] = [
  ch1Notes,
  ch2Notes
]

// 获取章节笔记
export const getNotesByChapterId = (chapterId: string): ChapterNotes | undefined => {
  // 支持两种格式: 'ch1' 或 'chapter-1'
  const normalizedId = chapterId.startsWith('chapter-') 
    ? `ch${chapterId.replace('chapter-', '')}` 
    : chapterId
  return allNotes.find(n => n.id === normalizedId)
}

export default allNotes
